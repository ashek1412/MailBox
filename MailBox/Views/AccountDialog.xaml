<Window x:Class="MailBox.Views.AccountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MailBox.ViewModels"
        Title="{Binding Title}" Width="500" MinWidth="420"
        Height="640" MinHeight="560" MaxHeight="860"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize"
        Background="#F9FAFB">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="18" FontWeight="SemiBold"
                   Foreground="#111827" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Quick presets -->
                <TextBox Text="QUICK SETUP" FontSize="11" Foreground="#6B7280"
                         FontWeight="SemiBold" Margin="0,0,0,6"
                         IsReadOnly="True" Background="Transparent" BorderThickness="0" Padding="0"/>
                <WrapPanel Margin="0,0,0,16">
                    <Button Content="Gmail"   Margin="0,0,6,6" Padding="12,6"
                            Command="{Binding ApplyPresetCommand}" CommandParameter="gmail"
                            Style="{StaticResource PresetButton}"/>
                    <Button Content="Outlook" Margin="0,0,6,6" Padding="12,6"
                            Command="{Binding ApplyPresetCommand}" CommandParameter="outlook"
                            Style="{StaticResource PresetButton}"/>
                    <Button Content="Yahoo"   Margin="0,0,6,6" Padding="12,6"
                            Command="{Binding ApplyPresetCommand}" CommandParameter="yahoo"
                            Style="{StaticResource PresetButton}"/>
                    <Button Content="iCloud"  Margin="0,0,6,6" Padding="12,6"
                            Command="{Binding ApplyPresetCommand}" CommandParameter="icloud"
                            Style="{StaticResource PresetButton}"/>
                </WrapPanel>

                <!-- Basic info -->
                <TextBox Text="Display Name *" FontSize="12" Foreground="#4B5563"
                         IsReadOnly="True" Background="Transparent" BorderThickness="0" Padding="0"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FieldBox}" Margin="0,4,0,12"/>

                <TextBox Text="Email Address *" FontSize="12" Foreground="#4B5563"
                         IsReadOnly="True" Background="Transparent" BorderThickness="0" Padding="0"/>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FieldBox}" Margin="0,4,0,16"/>

                <!-- IMAP -->
                <Border Background="#F3F4F6" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBox Text="INCOMING MAIL (IMAP)" FontSize="11" FontWeight="SemiBold"
                                 Foreground="#6B7280" Margin="0,0,0,8"
                                 IsReadOnly="True" Background="Transparent" BorderThickness="0" Padding="0"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBox Text="Host" FontSize="12" Foreground="#4B5563"
                                         IsReadOnly="True" Background="Transparent" BorderThickness="0" Padding="0"/>
                                <TextBox Text="{Binding ImapHost, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FieldBox}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBox Text="Port" FontSize="12" Foreground="#4B5563"
                                         IsReadOnly="True" Background="Transparent" BorderThickness="0" Padding="0"/>
                                <TextBox Text="{Binding ImapPort, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FieldBox}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                        <TextBox Text="Encryption" FontSize="12" Foreground="#4B5563"
                                 Margin="0,8,0,4"
                                 IsReadOnly="True" Background="Transparent" BorderThickness="0" Padding="0"/>
                        <ComboBox SelectedValue="{Binding ImapEncryption, Mode=TwoWay}"
                                  SelectedValuePath="Tag"
                                  Style="{StaticResource FieldCombo}">
                            <ComboBoxItem Tag="ssl"  Content="SSL / TLS  (port 993)"/>
                            <ComboBoxItem Tag="tls"  Content="STARTTLS   (port 143)"/>
                            <ComboBoxItem Tag="none" Content="None        (not recommended)"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- SMTP -->
                <Border Background="#F3F4F6" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBox Text="OUTGOING MAIL (SMTP)" FontSize="11" FontWeight="SemiBold"
                                 Foreground="#6B7280" Margin="0,0,0,8"
                                 IsReadOnly="True" Background="Transparent" BorderThickness="0" Padding="0"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBox Text="Host" FontSize="12" Foreground="#4B5563"
                                         IsReadOnly="True" Background="Transparent" BorderThickness="0" Padding="0"/>
                                <TextBox Text="{Binding SmtpHost, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FieldBox}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBox Text="Port" FontSize="12" Foreground="#4B5563"
                                         IsReadOnly="True" Background="Transparent" BorderThickness="0" Padding="0"/>
                                <TextBox Text="{Binding SmtpPort, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FieldBox}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                        <TextBox Text="Encryption" FontSize="12" Foreground="#4B5563"
                                 Margin="0,8,0,4"
                                 IsReadOnly="True" Background="Transparent" BorderThickness="0" Padding="0"/>
                        <ComboBox SelectedValue="{Binding SmtpEncryption, Mode=TwoWay}"
                                  SelectedValuePath="Tag"
                                  Style="{StaticResource FieldCombo}">
                            <ComboBoxItem Tag="tls"  Content="STARTTLS   (port 587)"/>
                            <ComboBoxItem Tag="ssl"  Content="SSL / TLS  (port 465)"/>
                            <ComboBoxItem Tag="none" Content="None        (not recommended)"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- SOCKS5 Proxy (optional) -->
                <Border Background="#F3F4F6" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBox Text="SOCKS5 PROXY (OPTIONAL)" FontSize="11" FontWeight="SemiBold"
                                 Foreground="#6B7280" Margin="0,0,0,4"
                                 IsReadOnly="True" Background="Transparent" BorderThickness="0" Padding="0"/>
                        <TextBox Text="Route all connections via VPN proxy. Leave blank for direct connection."
                                 FontSize="11" Foreground="#9CA3AF" Margin="0,0,0,8"
                                 IsReadOnly="True" Background="Transparent" BorderThickness="0" Padding="0"
                                 TextWrapping="Wrap"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBox Text="Host (e.g. 127.0.0.1)" FontSize="12" Foreground="#4B5563"
                                         IsReadOnly="True" Background="Transparent" BorderThickness="0" Padding="0"/>
                                <TextBox Text="{Binding ProxyHost, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FieldBox}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBox Text="Port" FontSize="12" Foreground="#4B5563"
                                         IsReadOnly="True" Background="Transparent" BorderThickness="0" Padding="0"/>
                                <TextBox Text="{Binding ProxyPort, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FieldBox}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Credentials -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBox Text="Username *" FontSize="12" Foreground="#4B5563"
                                 IsReadOnly="True" Background="Transparent" BorderThickness="0" Padding="0"/>
                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldBox}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBox Text="{Binding IsEdit, Converter={StaticResource SaveButtonText},
                                        ConverterParameter=password, Mode=OneWay}"
                                 FontSize="12" Foreground="#4B5563"
                                 IsReadOnly="True" Background="Transparent" BorderThickness="0" Padding="0"/>
                        <PasswordBox x:Name="PasswordBox" Style="{StaticResource FieldPassword}" Margin="0,4,0,0"
                                     PasswordChanged="PasswordBox_PasswordChanged"/>
                    </StackPanel>
                </Grid>

                <!-- Test connection + reset sync -->
                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                    <Button Content="Test IMAP Connection" Padding="12,6"
                            Command="{Binding TestConnectionCommand}"
                            Style="{StaticResource LinkButton}"/>
                    <Button Content="Reset sync state" Padding="12,6" Margin="8,0,0,0"
                            Command="{Binding ResetSyncCommand}"
                            Style="{StaticResource LinkButton}"
                            Foreground="#EF4444"
                            Visibility="{Binding IsEdit, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBox Text="{Binding TestResult, Mode=OneWay}" VerticalAlignment="Center" Margin="8,0,0,0"
                             Foreground="{Binding TestResult, Converter={StaticResource TestResultColor}}"
                             IsReadOnly="True" Background="Transparent" BorderThickness="0" Padding="0"/>
                </StackPanel>

                <!-- Error -->
                <TextBox Text="{Binding ErrorMessage, Mode=OneWay}" Foreground="#EF4444"
                         FontSize="12" Margin="0,8,0,0"
                         IsReadOnly="True" Background="Transparent" BorderThickness="0" Padding="0"
                         Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Padding="16,8" Margin="0,0,8,0"
                    Command="{Binding CancelCommand}" Style="{StaticResource SecondaryButton}"/>
            <Button Padding="16,8" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}">
                <TextBlock Text="{Binding IsEdit, Converter={StaticResource SaveButtonText}}"
                           Foreground="White" FontWeight="SemiBold" FontFamily="Segoe UI"/>
            </Button>
        </StackPanel>
    </Grid>
</Window>
