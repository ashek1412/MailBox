<UserControl x:Class="MailBox.Views.EmailListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MailBox.ViewModels"
             Background="White"
             PreviewKeyDown="OnPreviewKeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="12,10">
            <StackPanel>
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding FolderTitle}" FontSize="15" FontWeight="SemiBold"
                                   Foreground="#111827"/>
                        <TextBlock Text="{Binding AccountEmail}" FontSize="11" Foreground="#9CA3AF"
                                   Margin="0,1,0,0"
                                   Visibility="{Binding AccountEmail, Converter={StaticResource StringToVisibility}}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button ToolTip="Select emails" Width="28" Height="28"
                                Command="{Binding ToggleSelectModeCommand}"
                                Margin="0,0,4,0" FontSize="13" FontFamily="Segoe UI Emoji">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowSelectMode}" Value="True">
                                            <Setter Property="Background" Value="#EFF6FF"/>
                                            <Setter Property="Foreground" Value="#2563EB"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="☑" FontFamily="Segoe UI Emoji"/>
                        </Button>
                        <Button Style="{StaticResource IconButton}" ToolTip="Refresh"
                                Command="{Binding RefreshCommand}" Content="↺" FontSize="16"/>
                    </StackPanel>
                </Grid>
                <Grid Margin="0,8,0,0">
                    <TextBox Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FieldBox}" Padding="28,6,28,6"
                             x:Name="SearchBox">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding DoSearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <TextBlock Text="🔍" IsHitTestVisible="False" Margin="8,0" FontFamily="Segoe UI Emoji"
                               FontSize="12" Foreground="#9CA3AF" VerticalAlignment="Center"/>
                    <Button Content="✕" Style="{StaticResource IconButton}" Width="22" Height="22"
                            HorizontalAlignment="Right" Margin="0,0,4,0"
                            Command="{Binding ClearSearchCommand}"
                            Visibility="{Binding Search, Converter={StaticResource StringToVisibility}}"/>
                </Grid>

                <!-- Filter pills -->
                <Grid Margin="0,7,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Unread" Padding="10,4" FontSize="11"
                                Command="{Binding ToggleUnreadFilterCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background"      Value="Transparent"/>
                                    <Setter Property="Foreground"      Value="#6B7280"/>
                                    <Setter Property="BorderBrush"     Value="#E5E7EB"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="FontFamily"      Value="Segoe UI"/>
                                    <Setter Property="Cursor"          Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="12" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowUnreadOnly}" Value="True">
                                            <Setter Property="Background"  Value="#EFF6FF"/>
                                            <Setter Property="Foreground"  Value="#2563EB"/>
                                            <Setter Property="BorderBrush" Value="#BFDBFE"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                    <!-- Select All — only visible in select mode -->
                    <Button Content="Select All" Padding="10,4" FontSize="11"
                            HorizontalAlignment="Right"
                            Command="{Binding SelectAllCommand}"
                            Visibility="{Binding ShowSelectMode, Converter={StaticResource BoolToVisibility}}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"      Value="Transparent"/>
                                <Setter Property="Foreground"      Value="#6B7280"/>
                                <Setter Property="BorderBrush"     Value="#E5E7EB"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="FontFamily"      Value="Segoe UI"/>
                                <Setter Property="Cursor"          Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="12" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <!-- Selection action bar (visible when emails are checked) -->
                <Grid Margin="0,8,0,0"
                      Visibility="{Binding HasAnySelected, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontSize="12" Foreground="#374151" VerticalAlignment="Center">
                            <Run Text="{Binding SelectedCount, Mode=OneWay}"/>
                            <Run Text=" selected"/>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="✕ Clear" Padding="8,4" FontSize="12" Margin="0,0,6,0"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding ClearSelectionCommand}"/>
                        <Button Padding="8,4" FontSize="12"
                                Command="{Binding DeleteSelectedCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                    <Setter Property="Background"   Value="#EF4444"/>
                                    <Setter Property="BorderBrush"  Value="#EF4444"/>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="🗑 Delete" Foreground="White" FontFamily="Segoe UI Emoji"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Email rows -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Emails}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:EmailRowViewModel}">
                        <Button Style="{StaticResource EmailRow}" Command="{Binding SelectCommand}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/> <!-- checkbox -->
                                    <ColumnDefinition Width="44"/>   <!-- avatar -->
                                    <ColumnDefinition Width="*"/>    <!-- content -->
                                    <ColumnDefinition Width="Auto"/> <!-- date/icons -->
                                </Grid.ColumnDefinitions>

                                <!-- Checkbox — hidden unless select mode is on -->
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsChecked}"
                                          Width="20" Margin="4,0,4,0"
                                          VerticalAlignment="Center" HorizontalAlignment="Center"
                                          Click="CheckBox_Click"
                                          Visibility="{Binding DataContext.ShowSelectMode,
                                              RelativeSource={RelativeSource AncestorType=UserControl},
                                              Converter={StaticResource BoolToVisibility}}"/>

                                <!-- Avatar with unread dot -->
                                <Grid Grid.Column="1" VerticalAlignment="Top" Margin="0,2,8,0">
                                    <Border Width="34" Height="34" CornerRadius="17"
                                            Background="#DBEAFE">
                                        <TextBlock Text="{Binding Email.AvatarLetter}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontWeight="Bold" FontSize="13" Foreground="#1D4ED8"/>
                                    </Border>
                                    <Ellipse Width="10" Height="10" Fill="#2563EB"
                                             HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                             Margin="0,0,-2,-2">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Email.IsReadBool}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                </Grid>

                                <!-- Sender + Subject -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Email.DisplaySender}"
                                               FontSize="13" Foreground="#111827"
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="Normal"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Email.IsReadBool}" Value="False">
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Email.Subject}" FontSize="12"
                                               Foreground="#4B5563" TextTrimming="CharacterEllipsis"
                                               Margin="0,2,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="Normal"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Email.IsReadBool}" Value="False">
                                                        <Setter Property="FontWeight" Value="Medium"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Date + icons -->
                                <StackPanel Grid.Column="3" VerticalAlignment="Top"
                                            HorizontalAlignment="Right" Margin="8,2,0,0">
                                    <TextBlock Text="{Binding Email.FormattedDate}"
                                               FontSize="11" Foreground="#9CA3AF"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                                Margin="0,3,0,0">
                                        <TextBlock Text="📎" FontFamily="Segoe UI Emoji" FontSize="11"
                                                   Margin="0,0,2,0"
                                                   Visibility="{Binding Email.HasAttachmentBool,
                                                                Converter={StaticResource BoolToVisibility}}"/>
                                        <TextBlock Text="⭐" FontFamily="Segoe UI Emoji" FontSize="11"
                                                   Visibility="{Binding Email.IsFlaggedBool,
                                                                Converter={StaticResource BoolToVisibility}}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty state -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Emails.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <TextBlock Text="📭" FontFamily="Segoe UI Emoji" FontSize="44"
                       HorizontalAlignment="Center"/>
            <TextBlock HorizontalAlignment="Center" Margin="0,8,0,0" Foreground="#9CA3AF" FontSize="13">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="No emails here"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowUnreadOnly}" Value="True">
                                <Setter Property="Text" Value="No unread emails"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <TextBlock HorizontalAlignment="Center" Margin="0,4,0,0" Foreground="#D1D5DB" FontSize="12">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="Sync an account to download mail"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowUnreadOnly}" Value="True">
                                <Setter Property="Text" Value="All messages in this folder are read"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>

        <!-- Loading overlay -->
        <Border Grid.Row="1" Background="#A0FFFFFF"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="120" Height="4" Margin="0,0,0,8"/>
                <TextBlock Text="Loading…" HorizontalAlignment="Center"
                           Foreground="#6B7280" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- Pagination -->
        <Border Grid.Row="2" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="12,7"
                Visibility="{Binding TotalEmails, Converter={StaticResource IntToVisibility}}">
            <Grid>
                <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="#6B7280">
                    <Run Text="{Binding TotalEmails, Mode=OneWay}"/>
                    <Run Text=" emails"/>
                </TextBlock>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="‹ Prev" Style="{StaticResource SecondaryButton}"
                            Padding="10,5" FontSize="12"
                            Command="{Binding PrevPageCommand}"
                            IsEnabled="{Binding CanPrev}"/>
                    <TextBlock VerticalAlignment="Center" Margin="10,0" FontSize="12"
                               Foreground="#374151">
                        <Run Text="Page "/>
                        <Run Text="{Binding CurrentPage, Mode=OneWay}" FontWeight="SemiBold"/>
                        <Run Text=" of "/>
                        <Run Text="{Binding TotalPages, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>
                    <Button Content="Next ›" Style="{StaticResource SecondaryButton}"
                            Padding="10,5" FontSize="12"
                            Command="{Binding NextPageCommand}"
                            IsEnabled="{Binding CanNext}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
