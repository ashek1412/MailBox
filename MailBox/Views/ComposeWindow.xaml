<Window x:Class="MailBox.Views.ComposeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="{Binding WindowTitle}" Height="660" Width="700"
        MinWidth="500" MinHeight="440"
        WindowStartupLocation="CenterScreen"
        Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: Header -->
            <RowDefinition Height="Auto"/>  <!-- 1: From -->
            <RowDefinition Height="Auto"/>  <!-- 2: To -->
            <RowDefinition Height="Auto"/>  <!-- 3: Cc -->
            <RowDefinition Height="Auto"/>  <!-- 4: Bcc -->
            <RowDefinition Height="Auto"/>  <!-- 5: Subject -->
            <RowDefinition Height="Auto"/>  <!-- 6: Attachment chips -->
            <RowDefinition Height="*"/>     <!-- 7: Toolbar + Body -->
            <RowDefinition Height="Auto"/>  <!-- 8: Footer -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1F2937" Padding="16,10">
            <Grid>
                <TextBlock Text="{Binding WindowTitle}" Foreground="White"
                           FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button Content="✕" Foreground="White" Background="Transparent"
                        BorderThickness="0" Width="28" Height="28"
                        HorizontalAlignment="Right" Cursor="Hand"
                        Click="CloseButton_Click" FontSize="16"/>
            </Grid>
        </Border>

        <!-- From (account selector) -->
        <Border Grid.Row="1" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="56"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="From" FontWeight="SemiBold" FontSize="13"
                           Foreground="#6B7280" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Accounts}"
                          SelectedItem="{Binding SelectedAccount}"
                          DisplayMemberPath="DisplayName"
                          Style="{StaticResource FieldCombo}"
                          BorderThickness="0" Padding="0,2" FontSize="13"/>
            </Grid>
        </Border>

        <!-- To field with autocomplete -->
        <Border Grid.Row="2" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="56"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="To" FontWeight="SemiBold" FontSize="13"
                           Foreground="#6B7280" VerticalAlignment="Center"/>
                <Grid Grid.Column="1">
                    <TextBox Text="{Binding To, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FieldBox}" BorderThickness="0" Padding="0,4"
                             x:Name="ToBox" TextChanged="ToBox_TextChanged"/>
                    <Popup IsOpen="{Binding HasSuggestions}" PlacementTarget="{Binding ElementName=ToBox}"
                           Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                        <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1"
                                CornerRadius="8" Effect="{StaticResource DropShadow}"
                                MinWidth="300" MaxHeight="200">
                            <ItemsControl ItemsSource="{Binding Suggestions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource SidebarItem}"
                                                HorizontalContentAlignment="Left"
                                                Command="{Binding DataContext.PickSuggestionCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="28" Height="28" CornerRadius="14"
                                                        Background="#DBEAFE" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding AvatarLetter}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontWeight="Bold" FontSize="12"
                                                               Foreground="#1D4ED8"/>
                                                </Border>
                                                <TextBlock Text="{Binding Label}" FontSize="13"
                                                           Foreground="#111827" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Popup>
                </Grid>
            </Grid>
        </Border>

        <!-- Cc -->
        <Border Grid.Row="3" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="56"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Cc" FontWeight="SemiBold" FontSize="13"
                           Foreground="#6B7280" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding Cc, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FieldBox}" BorderThickness="0" Padding="0,4"/>
            </Grid>
        </Border>

        <!-- Bcc -->
        <Border Grid.Row="4" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="56"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Bcc" FontWeight="SemiBold" FontSize="13"
                           Foreground="#6B7280" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding Bcc, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FieldBox}" BorderThickness="0" Padding="0,4"/>
            </Grid>
        </Border>

        <!-- Subject (with label) -->
        <Border Grid.Row="5" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="56"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Subject" FontWeight="SemiBold" FontSize="13"
                           Foreground="#6B7280" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding Subject, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FieldBox}" BorderThickness="0" Padding="0,4"
                         FontWeight="SemiBold" FontSize="14"/>
            </Grid>
        </Border>

        <!-- Attachment chips (hidden when none) -->
        <Border Grid.Row="6" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="12,6"
                Visibility="{Binding Attachments.Count, Converter={StaticResource IntToVisibility}}">
            <ItemsControl ItemsSource="{Binding Attachments}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#EFF6FF" CornerRadius="4" Padding="8,3"
                                Margin="0,0,6,4" BorderBrush="#BFDBFE" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📎" FontSize="11" VerticalAlignment="Center"
                                           FontFamily="Segoe UI Emoji"/>
                                <TextBlock Text="{Binding FileName}" FontSize="12" Foreground="#1D4ED8"
                                           VerticalAlignment="Center" Margin="4,0,0,0"/>
                                <Button Content="✕" FontSize="10" Background="Transparent"
                                        BorderThickness="0" Foreground="#6B7280" Cursor="Hand"
                                        Margin="6,0,0,0" Padding="2,0" VerticalAlignment="Center"
                                        Command="{Binding DataContext.RemoveAttachmentCommand,
                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Toolbar + Body editor -->
        <Grid Grid.Row="7">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Formatting toolbar -->
            <Border Grid.Row="0" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1"
                    Padding="10,5" Background="#F9FAFB">
                <StackPanel Orientation="Horizontal">
                    <!-- Bold -->
                    <Button Style="{StaticResource FormatButton}" Tag="bold"
                            Click="FormatButton_Click" ToolTip="Bold (Ctrl+B)">
                        <TextBlock Text="B" FontWeight="Bold" FontSize="13" Foreground="#374151"/>
                    </Button>
                    <!-- Italic -->
                    <Button Style="{StaticResource FormatButton}" Tag="italic"
                            Click="FormatButton_Click" ToolTip="Italic (Ctrl+I)">
                        <TextBlock Text="I" FontStyle="Italic" FontSize="13" Foreground="#374151"/>
                    </Button>
                    <!-- Underline -->
                    <Button Style="{StaticResource FormatButton}" Tag="underline"
                            Click="FormatButton_Click" ToolTip="Underline (Ctrl+U)">
                        <TextBlock FontSize="13" Foreground="#374151">
                            <Underline>U</Underline>
                        </TextBlock>
                    </Button>
                    <!-- Strikethrough -->
                    <Button Style="{StaticResource FormatButton}" Tag="strikeThrough"
                            Click="FormatButton_Click" ToolTip="Strikethrough">
                        <TextBlock FontSize="13" Foreground="#374151">
                            <Span TextDecorations="Strikethrough">S</Span>
                        </TextBlock>
                    </Button>

                    <Separator Width="1" Height="18" Margin="4,0" Background="#E5E7EB"/>

                    <!-- Bullet list -->
                    <Button Style="{StaticResource FormatButton}" Width="32"
                            Tag="insertUnorderedList" Click="FormatButton_Click" ToolTip="Bullet List">
                        <TextBlock Text="• —" FontSize="11" Foreground="#374151"/>
                    </Button>
                    <!-- Numbered list -->
                    <Button Style="{StaticResource FormatButton}" Width="32"
                            Tag="insertOrderedList" Click="FormatButton_Click" ToolTip="Numbered List">
                        <TextBlock Text="1. —" FontSize="11" Foreground="#374151"/>
                    </Button>

                    <Separator Width="1" Height="18" Margin="4,0" Background="#E5E7EB"/>

                    <!-- Indent / Outdent -->
                    <Button Style="{StaticResource FormatButton}" Tag="indent"
                            Click="FormatButton_Click" ToolTip="Indent">
                        <TextBlock Text="→" FontSize="13" Foreground="#374151"/>
                    </Button>
                    <Button Style="{StaticResource FormatButton}" Tag="outdent"
                            Click="FormatButton_Click" ToolTip="Outdent">
                        <TextBlock Text="←" FontSize="13" Foreground="#374151"/>
                    </Button>

                    <Separator Width="1" Height="18" Margin="4,0" Background="#E5E7EB"/>

                    <!-- Remove formatting -->
                    <Button Style="{StaticResource FormatButton}" Width="32"
                            Tag="removeFormat" Click="FormatButton_Click" ToolTip="Clear Formatting">
                        <TextBlock FontSize="12" Foreground="#6B7280">
                            <Run Text="T"/><Run Text="x" FontSize="9" BaselineAlignment="Subscript"/>
                        </TextBlock>
                    </Button>
                </StackPanel>
            </Border>

            <!-- WebView2 body editor -->
            <wv2:WebView2 Grid.Row="1" x:Name="BodyEditor" Margin="0"/>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="8" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="16,10"
                Background="#F9FAFB">
            <Grid>
                <Button Content="📎 Attach" Style="{StaticResource SecondaryButton}"
                        Padding="10,6" HorizontalAlignment="Left"
                        Command="{Binding AddAttachmentCommand}"
                        FontFamily="Segoe UI Emoji"/>

                <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626" FontSize="12"
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                            Padding="14,8" Margin="0,0,8,0" Click="CloseButton_Click"/>
                    <Button Style="{StaticResource SecondaryButton}" Padding="14,8" Margin="0,0,8,0"
                            Command="{Binding SaveDraftCommand}"
                            IsEnabled="{Binding IsSavingDraft, Converter={StaticResource InverseBool}}">
                        <TextBlock Text="Save Draft" FontSize="13" Foreground="#374151"/>
                    </Button>
                    <Button Style="{StaticResource PrimaryButton}" Padding="14,8"
                            Command="{Binding SendCommand}"
                            IsEnabled="{Binding IsSending, Converter={StaticResource InverseBool}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Visibility="{Binding IsSending, Converter={StaticResource BoolToVisibility}}"
                                       Text="Sending… " FontSize="13" Foreground="White"/>
                            <TextBlock Text="Send ✉" FontSize="13" FontFamily="Segoe UI Emoji"
                                       Foreground="White"
                                       Visibility="{Binding IsSending, Converter={StaticResource InverseBoolToVisibility}}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
