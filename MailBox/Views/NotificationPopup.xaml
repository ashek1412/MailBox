<Window x:Class="MailBox.Views.NotificationPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        ShowInTaskbar="False" Topmost="True"
        Width="340" SizeToContent="Height"
        Background="Transparent" Opacity="0"
        Cursor="Hand"
        MouseLeftButtonDown="OnClick">
    <Border Background="White" CornerRadius="10" Margin="10,6,10,10"
            BorderBrush="#E2E8F0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="3" Direction="270"
                              Color="#000000" Opacity="0.13"/>
        </Border.Effect>
        <Grid>
            <!-- blue left accent bar -->
            <Border Width="4" HorizontalAlignment="Left" CornerRadius="10,0,0,10"
                    Background="#1a73e8"/>
            <StackPanel Margin="16,12,14,12">
                <TextBlock x:Name="Line1" FontSize="13" FontWeight="SemiBold"
                           Foreground="#1a1a2e" TextWrapping="Wrap"/>
                <TextBlock x:Name="Line2" FontSize="12" Foreground="#64748B"
                           TextWrapping="Wrap" Margin="0,3,0,0" Visibility="Collapsed"/>
                <TextBlock x:Name="Line3" FontSize="12" Foreground="#64748B"
                           TextWrapping="Wrap" Margin="0,1,0,0" Visibility="Collapsed"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
