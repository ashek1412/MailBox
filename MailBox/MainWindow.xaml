<Window x:Class="MailBox.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MailBox.ViewModels"
        xmlns:v="clr-namespace:MailBox.Views"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="MailBox" Height="780" Width="1280"
        MinWidth="1000" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/mailbox.ico"
        Background="#F9FAFB"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing">

    <!-- DataTemplates: map ViewModels to Views for the right panel -->
    <Window.DataContext>
        <Binding/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <!-- Status bar -->
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <!-- ── 3-panel layout ── -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" MinWidth="60"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="340" MinWidth="240"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"   MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <v:SidebarView Grid.Column="0" DataContext="{Binding Sidebar}"/>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="#E5E7EB" ResizeBehavior="PreviousAndNext"/>

            <!-- Email list -->
            <v:EmailListView Grid.Column="2" DataContext="{Binding EmailList}"/>

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch"
                          Background="#E5E7EB" ResizeBehavior="PreviousAndNext"/>

            <!-- Right panel: email viewer or logs -->
            <ContentControl Grid.Column="4" Content="{Binding RightPanel}">
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type vm:EmailViewerViewModel}">
                        <v:EmailViewerView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:LogsViewModel}">
                        <v:LogsView/>
                    </DataTemplate>
                </ContentControl.Resources>
                <!-- Empty state when nothing selected -->
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Style.Triggers>
                            <Trigger Property="Content" Value="{x:Null}">
                                <Setter Property="ContentTemplate">
                                    <Setter.Value>
                                        <DataTemplate>
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="📬" FontSize="52" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Select an email to read"
                                                           FontSize="15" Foreground="#9CA3AF"
                                                           HorizontalAlignment="Center" Margin="0,12,0,4"/>
                                                <TextBlock Text="Choose a message from the list"
                                                           FontSize="12" Foreground="#D1D5DB"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="1" Background="#F3F4F6" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                           FontSize="11" Foreground="#6B7280"/>
                <ProgressBar IsIndeterminate="True" Width="80" Height="6"
                             HorizontalAlignment="Right" VerticalAlignment="Center"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Sync loading overlay -->
        <Grid Grid.RowSpan="2"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
              Background="#60000000" Panel.ZIndex="99">
            <Border Background="White" CornerRadius="12" Padding="40,28"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Effect="{StaticResource DropShadow}">
                <StackPanel>
                    <ProgressBar IsIndeterminate="True" Width="220" Height="4" Margin="0,0,0,16"/>
                    <TextBlock Text="Syncing…" FontSize="15" FontWeight="SemiBold"
                               Foreground="#374151" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
