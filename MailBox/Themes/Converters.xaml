<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:MailBox.Converters">
    <conv:BoolToVisibilityConverter        x:Key="BoolToVisibility"/>
    <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
    <conv:InverseBoolConverter             x:Key="InverseBool"/>
    <conv:StringToVisibilityConverter      x:Key="StringToVisibility"/>
    <conv:NullToVisibilityConverter        x:Key="NullToVisibility"/>
    <conv:BoolToFontWeightConverter        x:Key="BoolToFontWeight"/>
    <conv:HexToBrushConverter              x:Key="HexToBrush"/>
    <conv:TestResultColorConverter         x:Key="TestResultColor"/>
    <conv:SaveButtonTextConverter          x:Key="SaveButtonText"/>
    <conv:UnreadBadgeVisibilityConverter   x:Key="UnreadBadgeVisibility"/>
    <conv:BoolToChevronConverter           x:Key="BoolToChevron"/>
    <conv:IntToVisibilityConverter         x:Key="IntToVisibility"/>
    <conv:DateToStringConverter            x:Key="DateToString"/>
    <conv:StringToColorConverter           x:Key="StringToColor"/>
</ResourceDictionary>
